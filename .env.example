DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/hcc_db
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-with-a-secure-secret
API_PORT=3001
CMS_PORT=3002
KIOSK_PORT=3000
NEXT_PUBLIC_API_URL=http://127.0.0.1:3001
NEXT_PUBLIC_WS_URL=http://127.0.0.1:3001
TAURI_API_URL=http://apihcc.gvbsoft.vn
TAURI_WS_URL=http://apihcc.gvbsoft.vn
NEXT_PUBLIC_KIOSK_DEVICE_ID=KIOSK-001
# OTA CI/CD deploy token — must match the GitHub repo secret OTA_DEPLOY_TOKEN
OTA_DEPLOY_TOKEN=replace-with-a-strong-random-token

# AI Chatbot providers — seeded into the ai_runners table by
# scripts/seed-ai-providers.mjs (keys encrypted at rest). Leave blank to skip.
NVIDIA_API_KEY=
OPENROUTER_API_KEY=
