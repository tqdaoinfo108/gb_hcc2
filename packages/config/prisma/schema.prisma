generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum CommandType {
  RESTART_APP    @map("restart_app")
  RESTART_DEVICE @map("restart_device")
  LOCK           @map("lock")
  UNLOCK         @map("unlock")
  CLEAR_CACHE    @map("clear_cache")
  CAPTURE_SCREEN @map("capture_screen")
  PUSH_WORKFLOW  @map("push_workflow")
  UPDATE_CONFIG  @map("update_config")
}

enum CommandStatus {
  PENDING
  SENT
  ACK
  SUCCESS
  FAILED
  CANCELLED
}

enum WorkflowAction {
  OPEN
  CLICK
  INPUT
  UPLOAD
  WAIT
  ASSERT
  SCREENSHOT
}

enum WorkflowVersionStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum SelectorType {
  DATA_TESTID @map("data-testid")
  ARIA_LABEL  @map("aria-label")
  TEXT        @map("text")
  CSS         @map("css")
  XPATH       @map("xpath")
  IMAGE       @map("image")
}

enum SessionStatus {
  QUEUED
  RUNNING
  PAUSED
  SUCCESS
  FAILED
  CANCELLED
}

enum LogLevel {
  INFO
  WARN
  ERROR
}

enum OtaComponent {
  KIOSK_APP         @map("kiosk_app")
  AUTOMATION_ENGINE @map("automation_engine")
  WORKFLOW          @map("workflow")
  BROWSER           @map("browser")
  BROWSER_ENGINE    @map("browser_engine")
  CONFIG            @map("config")
}

enum OtaPackageStatus {
  DRAFT
  SIGNED
  ACTIVE
  ROLLED_BACK
}

enum OtaDeploymentStatus {
  PENDING
  DOWNLOADING
  VERIFYING
  BACKING_UP
  INSTALLING
  HEALTH_CHECK
  SUCCESS
  FAILED
  ROLLED_BACK
}

model User {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String      @unique
  passwordHash String      @map("password_hash")
  fullName     String      @map("full_name")
  status       UserStatus  @default(ACTIVE)
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  roles        UserRole[]
  commands     DeviceCommand[]
  auditLogs    AuditLog[]

  @@map("users")
}

model Role {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key         String           @unique
  description String?
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  roles       RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Device {
  id                     String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deviceId               String            @unique @map("device_id")
  location               String
  version                String            @default("0.0.0")
  ip                     String?
  status                 String            @default("offline")
  certificateFingerprint String?           @map("certificate_fingerprint")
  jwtSubject             String?           @map("jwt_subject")
  isLocked               Boolean           @default(false) @map("is_locked")
  lastSeenAt             DateTime?         @map("last_seen_at") @db.Timestamptz(6)
  createdAt              DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  statuses               DeviceStatus[]
  commands               DeviceCommand[]
  sessions               AutomationSession[]
  deployments            OtaDeployment[]

  @@map("devices")
}

model DeviceStatus {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deviceId       String   @map("device_id") @db.Uuid
  online         Boolean  @default(false)
  cpuPercent     Float?   @map("cpu_percent")
  ramPercent     Float?   @map("ram_percent")
  diskPercent    Float?   @map("disk_percent")
  temperatureC   Float?   @map("temperature_c")
  network        String?
  currentUrl     String?  @map("current_url")
  currentStep    String?  @map("current_step")
  lastHeartbeat  DateTime @default(now()) @map("last_heartbeat") @db.Timestamptz(6)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  device         Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, lastHeartbeat])
  @@map("device_status")
}

model DeviceCommand {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deviceId       String        @map("device_id") @db.Uuid
  command        CommandType
  payload        Json?
  status         CommandStatus @default(PENDING)
  response       Json?
  issuedById     String?       @map("issued_by_id") @db.Uuid
  issuedAt       DateTime      @default(now()) @map("issued_at") @db.Timestamptz(6)
  acknowledgedAt DateTime?     @map("acknowledged_at") @db.Timestamptz(6)
  completedAt    DateTime?     @map("completed_at") @db.Timestamptz(6)
  device         Device        @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  issuedBy       User?         @relation(fields: [issuedById], references: [id], onDelete: SetNull)

  @@index([deviceId, issuedAt])
  @@map("device_command")
}

model Workflow {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug          String            @unique
  name          String
  description   String?
  activeVersion String?           @map("active_version")
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  versions      WorkflowVersion[]
  selectors     Selector[]

  @@map("workflow")
}

model WorkflowVersion {
  id          String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workflowId  String                @map("workflow_id") @db.Uuid
  version     String
  definition  Json
  status      WorkflowVersionStatus @default(DRAFT)
  isActive    Boolean               @default(false) @map("is_active")
  signature   String?
  createdAt   DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  workflow    Workflow              @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  steps       WorkflowStep[]
  sessions    AutomationSession[]

  @@unique([workflowId, version])
  @@map("workflow_version")
}

model WorkflowStep {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workflowVersionId String          @map("workflow_version_id") @db.Uuid
  stepKey           String          @map("step_key")
  order             Int             @map("step_order")
  action            WorkflowAction
  targetUrl         String?         @map("target_url")
  selectorKey       String?         @map("selector_key")
  inputSource       String?         @map("input_source")
  timeoutMs         Int             @default(30000) @map("timeout_ms")
  retryCount        Int             @default(3) @map("retry_count")
  metadata          Json?
  workflowVersion   WorkflowVersion @relation(fields: [workflowVersionId], references: [id], onDelete: Cascade)

  @@unique([workflowVersionId, stepKey])
  @@map("workflow_step")
}

model Selector {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  selectorKey       String?           @unique @map("selector_key")
  workflowId        String?           @map("workflow_id") @db.Uuid
  workflowVersionId String?           @map("workflow_version_id") @db.Uuid
  stepKey           String?           @map("step_key")
  name              String?
  description       String?
  selectorType      SelectorType?     @map("selector_type")
  selectorValue     String?           @map("selector_value")
  priority          Int               @default(1)
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  workflow          Workflow?         @relation(fields: [workflowId], references: [id], onDelete: SetNull)
  versions          SelectorVersion[]

  @@map("selector")
}

model SelectorVersion {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  selectorId    String       @map("selector_id") @db.Uuid
  version       String
  selectorType  SelectorType @map("selector_type")
  selectorValue String       @map("selector_value")
  priority      Int          @default(1)
  isActive      Boolean      @default(false) @map("is_active")
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  selector      Selector     @relation(fields: [selectorId], references: [id], onDelete: Cascade)

  @@unique([selectorId, version])
  @@map("selector_version")
}

model AutomationSession {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deviceId          String?            @map("device_id") @db.Uuid
  workflowVersionId String?            @map("workflow_version_id") @db.Uuid
  status            SessionStatus
  startedAt         DateTime           @default(now()) @map("started_at") @db.Timestamptz(6)
  finishedAt        DateTime?          @map("finished_at") @db.Timestamptz(6)
  expiresAt         DateTime           @default(dbgenerated("now() + interval '15 minutes'")) @map("expires_at") @db.Timestamptz(6)
  currentStep       String?            @map("current_step")
  errorMessage      String?            @map("error_message")
  device            Device?            @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  workflowVersion   WorkflowVersion?   @relation(fields: [workflowVersionId], references: [id], onDelete: SetNull)
  logs              AutomationLog[]
  aiConversations   AiConversation[]

  @@index([status])
  @@map("automation_session")
}

model AutomationLog {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId      String            @map("session_id") @db.Uuid
  stepKey        String?           @map("step_key")
  level          LogLevel
  message        String
  durationMs     Int?              @map("duration_ms")
  screenshotUrl  String?           @map("screenshot_url")
  videoUrl       String?           @map("video_url")
  domSnapshotUrl String?           @map("dom_snapshot_url")
  htmlSnapshot   String?           @map("html_snapshot")
  consoleLog     Json?             @map("console_log")
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  session        AutomationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("automation_log")
}

model OtaPackage {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  component     OtaComponent
  version       String
  packageUrl    String           @map("package_url")
  sha256        String
  signature     String
  status        OtaPackageStatus @default(DRAFT)
  metadata      Json?
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  deployments   OtaDeployment[]

  @@unique([component, version])
  @@map("ota_package")
}

model OtaDeployment {
  id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  packageId      String              @map("package_id") @db.Uuid
  deviceId       String              @map("device_id") @db.Uuid
  status         OtaDeploymentStatus @default(PENDING)
  startedAt      DateTime?           @map("started_at") @db.Timestamptz(6)
  completedAt    DateTime?           @map("completed_at") @db.Timestamptz(6)
  rollbackReason String?             @map("rollback_reason")
  healthCheck    Json?               @map("health_check")
  otaPackage     OtaPackage          @relation(fields: [packageId], references: [id], onDelete: Cascade)
  device         Device              @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([packageId, deviceId])
  @@map("ota_deployment")
}

model AiConversation {
  id                   String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId            String?            @map("session_id") @db.Uuid
  userQuestion         String             @map("user_question")
  workflowState        Json?              @map("workflow_state")
  automationError      Json?              @map("automation_error")
  assistantInstruction String             @map("assistant_instruction")
  nextAction           String?            @map("next_action")
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  session              AutomationSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@map("ai_conversation")
}

model SystemConfig {
  key       String   @id
  value     Json
  isSecret  Boolean  @default(false) @map("is_secret")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("system_config")
}

model AuditLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  action      String
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@map("audit_log")
}
