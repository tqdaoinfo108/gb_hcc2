// ═══════════════════════════════════════════════════════════════
// Smart Government Kiosk Platform — Enterprise Database Schema
// ═══════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ════════════════════════════════════════════════════
// MODULE 1 — KIOSK DEVICE & LOCATION
// ════════════════════════════════════════════════════

model KioskLocation {
  id         String    @id @default(uuid())
  code       String    @unique
  name       String
  address    String
  district   String?
  province   String?
  lat        Float?
  lng        Float?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  devices          KioskDevice[]
  userLocations    UserLocation[]
  homeServices     KioskHomeService[]
  queueServices    QueueService[]
  copyDocCategories CopyDocCategory[]

  @@map("kiosk_locations")
}

model KioskDevice {
  id              String            @id @default(uuid())
  deviceId        String            @unique
  locationId      String
  serialNumber    String            @unique
  name            String?
  placement       String?
  isEnabled       Boolean           @default(true)
  maintenanceMessage String?
  tickerText      String?
  model           String?
  firmwareVersion String?
  ipAddress       String?
  macAddress      String?
  status          KioskDeviceStatus @default(OFFLINE)
  lastHeartbeat   DateTime?
  installedAt     DateTime?
  metadata        Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?

  location     KioskLocation    @relation(fields: [locationId], references: [id])
  sessions     KioskSession[]
  components   KioskComponent[]
  healthLogs   KioskHealthLog[]
  actions      KioskAction[]
  queueTickets QueueTicket[]
  statistics   KioskStatistic[]

  @@index([locationId])
  @@index([status])
  @@map("kiosk_devices")
}

enum KioskDeviceStatus {
  ONLINE
  OFFLINE
  MAINTENANCE
  ERROR
}

model KioskComponent {
  id          String          @id @default(uuid())
  deviceId    String
  type        ComponentType
  name        String
  status      ComponentStatus @default(UNKNOWN)
  lastChecked DateTime?
  metadata    Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?

  device KioskDevice @relation(fields: [deviceId], references: [id])

  @@index([deviceId])
  @@map("kiosk_components")
}

enum ComponentType {
  CAMERA
  SCANNER
  PRINTER
  NFC_READER
  CARD_READER
  SCREEN
  NETWORK
  AUDIO
}

enum ComponentStatus {
  OK
  WARNING
  ERROR
  UNKNOWN
}

model KioskHealthLog {
  id             String            @id @default(uuid())
  deviceId       String
  cpuUsage       Float?
  memoryUsage    Float?
  diskUsage      Float?
  temperatureC   Float?
  networkLatency Int?
  ipAddress      String?
  hostname       String?
  os             String?
  browser        String?
  appVersion     String?
  screenResolution String?
  userAgent      String?
  currentScreen  String?
  sessionId      String?
  status         KioskDeviceStatus
  components     Json?
  createdAt      DateTime          @default(now())

  device KioskDevice @relation(fields: [deviceId], references: [id])

  @@index([deviceId])
  @@index([createdAt])
  @@map("kiosk_health_logs")
}

model KioskAction {
  id          String   @id @default(uuid())
  deviceId    String
  adminId     String?
  action      String
  payload     Json?
  result      String?
  performedAt DateTime @default(now())

  device KioskDevice @relation(fields: [deviceId], references: [id])

  @@index([deviceId])
  @@map("kiosk_actions")
}

// ════════════════════════════════════════════════════
// MODULE 2 — KIOSK SESSION MANAGEMENT
// ════════════════════════════════════════════════════

model KioskSession {
  id              String        @id @default(uuid())
  deviceId        String
  citizenId       String?
  sessionToken    String        @unique @default(uuid())
  currentScreen   String?
  status          SessionStatus @default(ACTIVE)
  language        String        @default("vi")
  startTime       DateTime      @default(now())
  endTime         DateTime?
  lastActivityAt  DateTime      @default(now())
  securityCleaned Boolean       @default(false)
  cleanedAt       DateTime?
  ipAddress       String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  device          KioskDevice              @relation(fields: [deviceId], references: [id])
  citizen         Citizen?                 @relation(fields: [citizenId], references: [id])
  events          KioskSessionEvent[]
  timeoutLogs     KioskSessionTimeoutLog[]
  applications    Application[]
  aiConversations AIConversation[]
  queueTickets    QueueTicket[]
  feedbacks       Feedback[]

  @@index([deviceId])
  @@index([citizenId])
  @@index([status])
  @@index([startTime])
  @@map("kiosk_sessions")
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  EXPIRED
  ERROR
  TERMINATED
}

model KioskSessionEvent {
  id        String   @id @default(uuid())
  sessionId String
  screen    String?
  eventType String
  eventData Json?
  createdAt DateTime @default(now())

  session KioskSession @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
  @@index([createdAt])
  @@map("kiosk_session_events")
}

model KioskSessionTimeoutLog {
  id             String   @id @default(uuid())
  sessionId      String
  timeoutType    String
  secondsElapsed Int
  actionTaken    String?
  createdAt      DateTime @default(now())

  session KioskSession @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
  @@map("kiosk_session_timeout_logs")
}

// ════════════════════════════════════════════════════
// MODULE 3 — CITIZEN IDENTITY
// ════════════════════════════════════════════════════

model Citizen {
  id             String    @id @default(uuid())
  nationalId     String    @unique
  fullName       String
  dateOfBirth    DateTime?
  gender         String?
  phone          String?
  email          String?
  province       String?
  district       String?
  ward           String?
  address        String?
  vneidLinked    Boolean   @default(false)
  vneidId        String?
  isActive       Boolean   @default(true)
  consentGiven   Boolean   @default(false)
  consentAt      DateTime?
  lastVerifiedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  profile       CitizenProfile?
  verifications IdentityVerification[]
  authLogs      AuthenticationLog[]
  sessions      KioskSession[]
  documents     DigitalDocument[]
  applications  Application[]

  @@index([nationalId])
  @@map("citizens")
}

model CitizenProfile {
  id             String    @id @default(uuid())
  citizenId      String    @unique
  avatarUrl      String?
  occupation     String?
  educationLevel String?
  ethnicGroup    String?
  religion       String?
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  citizen Citizen @relation(fields: [citizenId], references: [id])

  @@map("citizen_profiles")
}

model IdentityVerification {
  id            String             @id @default(uuid())
  citizenId     String
  sessionId     String?
  method        VerificationMethod
  status        VerificationStatus @default(PENDING)
  verifiedData  Json?
  confidence    Float?
  failureReason String?
  verifiedAt    DateTime?
  expiresAt     DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  deletedAt     DateTime?

  citizen Citizen @relation(fields: [citizenId], references: [id])

  @@index([citizenId])
  @@index([method])
  @@map("identity_verifications")
}

enum VerificationMethod {
  CCCD_CHIP
  CCCD_SCAN
  VNEID_QR
  FACE
  MANUAL_STAFF
}

enum VerificationStatus {
  PENDING
  VERIFIED
  FAILED
  EXPIRED
}

model AuthenticationLog {
  id         String             @id @default(uuid())
  citizenId  String
  sessionId  String?
  method     VerificationMethod
  success    Boolean
  ipAddress  String?
  deviceId   String?
  failReason String?
  createdAt  DateTime           @default(now())

  citizen Citizen @relation(fields: [citizenId], references: [id])

  @@index([citizenId])
  @@index([createdAt])
  @@map("authentication_logs")
}

// ════════════════════════════════════════════════════
// MODULE 4 — DIGITAL DOCUMENT WALLET
// ════════════════════════════════════════════════════

model DocumentCategory {
  id        String    @id @default(uuid())
  code      String    @unique
  name      String
  nameEn    String?
  icon      String?
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  documents DigitalDocument[]

  @@map("document_categories")
}

model DigitalDocument {
  id                 String               @id @default(uuid())
  ownerId            String
  categoryId         String
  title              String
  documentType       String
  documentNumber     String?
  issuedBy           String?
  issuedDate         DateTime?
  expiryDate         DateTime?
  verificationStatus DocVerificationStatus @default(UNVERIFIED)
  verifiedAt         DateTime?
  verifiedBy         String?
  isReusable         Boolean              @default(true)
  isActive           Boolean              @default(true)
  metadata           Json?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  deletedAt          DateTime?

  owner           Citizen               @relation(fields: [ownerId], references: [id])
  category        DocumentCategory      @relation(fields: [categoryId], references: [id])
  versions        DocumentVersion[]
  files           DocumentFile[]
  accessLogs      DocumentAccessLog[]
  applicationDocs ApplicationDocument[]

  @@index([ownerId])
  @@index([categoryId])
  @@index([verificationStatus])
  @@map("digital_documents")
}

enum DocVerificationStatus {
  UNVERIFIED
  VERIFIED
  REJECTED
  EXPIRED
}

model DocumentVersion {
  id         String   @id @default(uuid())
  documentId String
  version    Int
  changedBy  String?
  changeNote String?
  snapshot   Json
  createdAt  DateTime @default(now())

  document DigitalDocument @relation(fields: [documentId], references: [id])

  @@index([documentId])
  @@map("document_versions")
}

model DocumentFile {
  id          String    @id @default(uuid())
  documentId  String
  fileName    String
  mimeType    String
  sizeBytes   Int?
  storagePath String
  bucketName  String
  checksum    String?
  isEncrypted Boolean   @default(true)
  uploadedAt  DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  document DigitalDocument @relation(fields: [documentId], references: [id])

  @@index([documentId])
  @@map("document_files")
}

model DocumentAccessLog {
  id           String   @id @default(uuid())
  documentId   String
  accessorId   String?
  accessorType String?
  action       String
  sessionId    String?
  ipAddress    String?
  createdAt    DateTime @default(now())

  document DigitalDocument @relation(fields: [documentId], references: [id])

  @@index([documentId])
  @@index([createdAt])
  @@map("document_access_logs")
}

// ════════════════════════════════════════════════════
// MODULE 5 — ADMINISTRATIVE PROCEDURE MANAGEMENT
// ════════════════════════════════════════════════════

model ProcedureCategory {
  id        String    @id @default(uuid())
  code      String    @unique
  name      String
  nameEn    String?
  icon      String?
  colorHex  String?
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  parentId  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  parent     ProcedureCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children   ProcedureCategory[] @relation("CategoryTree")
  procedures Procedure[]

  @@map("procedure_categories")
}

model Procedure {
  id               String    @id @default(uuid())
  categoryId       String
  code             String    @unique
  name             String
  nameEn           String?
  description      String?
  legalBasis       String?
  processingAgency String?
  slaWorkDays      Int       @default(5)
  fee              Decimal?  @db.Decimal(15, 2)
  feeNote          String?
  isOnline         Boolean   @default(true)
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  category     ProcedureCategory      @relation(fields: [categoryId], references: [id])
  versions     ProcedureVersion[]
  requirements ProcedureRequirement[]
  workflows    ProcedureWorkflow[]
  applications Application[]

  @@index([categoryId])
  @@index([code])
  @@map("procedures")
}

model ProcedureVersion {
  id            String    @id @default(uuid())
  procedureId   String
  version       String
  releaseNote   String?
  isActive      Boolean   @default(true)
  effectiveFrom DateTime
  effectiveTo   DateTime?
  snapshot      Json
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  procedure Procedure @relation(fields: [procedureId], references: [id])

  @@index([procedureId])
  @@map("procedure_versions")
}

model ProcedureRequirement {
  id              String    @id @default(uuid())
  procedureId     String
  documentType    String
  documentName    String
  description     String?
  isRequired      Boolean   @default(true)
  acceptedFormats String[]
  maxFileSizeMB   Int       @default(10)
  sortOrder       Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  procedure Procedure @relation(fields: [procedureId], references: [id])

  @@index([procedureId])
  @@map("procedure_requirements")
}

model ProcedureWorkflow {
  id          String    @id @default(uuid())
  procedureId String
  stepOrder   Int
  stepName    String
  stepCode    String
  description String?
  assignedTo  String?
  slaHours    Int?
  isRequired  Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  procedure Procedure @relation(fields: [procedureId], references: [id])

  @@index([procedureId])
  @@map("procedure_workflows")
}

// ════════════════════════════════════════════════════
// MODULE 6 — ONLINE APPLICATION (HỒ SƠ)
// ════════════════════════════════════════════════════

model Application {
  id               String            @id @default(uuid())
  sessionId        String
  citizenId        String
  procedureId      String
  organizationId   String?
  trackingCode     String            @unique
  status           ApplicationStatus @default(DRAFT)
  submittedAt      DateTime?
  expectedResultAt DateTime?
  completedAt      DateTime?
  counterNumber    String?
  processingNote   String?
  rejectionReason  String?
  formData         Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?

  session       KioskSession               @relation(fields: [sessionId], references: [id])
  citizen       Citizen                    @relation(fields: [citizenId], references: [id])
  procedure     Procedure                  @relation(fields: [procedureId], references: [id])
  documents     ApplicationDocument[]
  statusHistory ApplicationStatusHistory[]
  receipts      SubmissionReceipt[]

  @@index([citizenId])
  @@index([sessionId])
  @@index([procedureId])
  @@index([status])
  @@index([trackingCode])
  @@map("applications")
}

enum ApplicationStatus {
  DRAFT
  PREPARING
  SUBMITTED
  PROCESSING
  ADDITIONAL_INFO_REQUIRED
  COMPLETED
  REJECTED
  CANCELLED
  WITHDRAWN
}

model ApplicationDocument {
  id                 String               @id @default(uuid())
  applicationId      String
  documentId         String?
  requirementId      String?
  fileName           String?
  storagePath        String?
  bucketName         String?
  mimeType           String?
  sizeBytes          Int?
  verificationStatus DocVerificationStatus @default(UNVERIFIED)
  uploadedAt         DateTime             @default(now())
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  deletedAt          DateTime?

  application Application      @relation(fields: [applicationId], references: [id])
  document    DigitalDocument? @relation(fields: [documentId], references: [id])

  @@index([applicationId])
  @@index([documentId])
  @@map("application_documents")
}

model ApplicationStatusHistory {
  id            String             @id @default(uuid())
  applicationId String
  fromStatus    ApplicationStatus?
  toStatus      ApplicationStatus
  changedBy     String?
  note          String?
  createdAt     DateTime           @default(now())

  application Application @relation(fields: [applicationId], references: [id])

  @@index([applicationId])
  @@map("application_status_history")
}

model SubmissionReceipt {
  id            String    @id @default(uuid())
  applicationId String
  receiptNumber String    @unique
  receiptData   Json
  printedAt     DateTime?
  qrCode        String?
  storagePath   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  application Application @relation(fields: [applicationId], references: [id])

  @@index([applicationId])
  @@map("submission_receipts")
}

// ════════════════════════════════════════════════════
// MODULE 7 — KIOSK HOME SERVICE CONFIG
// ════════════════════════════════════════════════════

model KioskHomeService {
  id          String    @id @default(uuid())
  /// null = mặc định chung (áp cho mọi địa điểm chưa cấu hình riêng).
  locationId  String?
  code        String
  name        String
  nameEn      String?
  description String?
  icon        String?
  colorHex    String?
  bgColorHex  String?
  screenId    String
  badge       String?
  sortOrder   Int       @default(0)
  isVisible   Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  location KioskLocation? @relation(fields: [locationId], references: [id])

  @@unique([locationId, code])
  @@index([locationId])
  @@map("kiosk_home_services")
}

// ════════════════════════════════════════════════════
// MODULE 8 — QUEUE MANAGEMENT
// ════════════════════════════════════════════════════

model QueueService {
  id            String    @id @default(uuid())
  locationId    String?   // null = dùng chung cho mọi địa điểm
  code          String
  name          String
  nameEn        String?
  description   String?
  colorHex      String?
  prefix        String    @default("A")
  currentNumber Int       @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  location    KioskLocation?        @relation(fields: [locationId], references: [id])
  counters    Counter[]
  tickets     QueueTicket[]
  dailyStats  QueueDailyStatistic[]

  @@unique([locationId, code])
  @@index([locationId])
  @@map("queue_services")
}

model Counter {
  id              String        @id @default(uuid())
  serviceId       String
  number          String
  name            String?
  operatorId      String?
  status          CounterStatus @default(CLOSED)
  currentTicketId String?
  openedAt        DateTime?
  closedAt        DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  service QueueService  @relation(fields: [serviceId], references: [id])
  tickets QueueTicket[]

  @@index([serviceId])
  @@map("counters")
}

enum CounterStatus {
  OPEN
  BUSY
  PAUSED
  CLOSED
}

model QueueTicket {
  id               String       @id @default(uuid())
  serviceId        String
  kioskId          String?
  sessionId        String?
  ticketNumber     Int
  displayNumber    String
  status           TicketStatus @default(WAITING)
  counterId        String?
  priority         Int          @default(0)
  estimatedWaitMin Int?
  issuedAt         DateTime     @default(now())
  calledAt         DateTime?
  servedAt         DateTime?
  completedAt      DateTime?
  missedAt         DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?

  service  QueueService  @relation(fields: [serviceId], references: [id])
  device   KioskDevice?  @relation(fields: [kioskId], references: [id])
  session  KioskSession? @relation(fields: [sessionId], references: [id])
  counter  Counter?      @relation(fields: [counterId], references: [id])
  events   QueueEvent[]

  @@index([serviceId])
  @@index([status])
  @@index([issuedAt])
  @@map("queue_tickets")
}

enum TicketStatus {
  WAITING
  CALLED
  SERVING
  COMPLETED
  MISSED
  CANCELLED
}

model QueueEvent {
  id         String   @id @default(uuid())
  ticketId   String
  eventType  String
  note       String?
  operatorId String?
  createdAt  DateTime @default(now())

  ticket QueueTicket @relation(fields: [ticketId], references: [id])

  @@index([ticketId])
  @@map("queue_events")
}

model QueueDailyStatistic {
  id              String   @id @default(uuid())
  serviceId       String
  date            DateTime @db.Date
  totalIssued     Int      @default(0)
  totalCompleted  Int      @default(0)
  totalMissed     Int      @default(0)
  avgWaitTimeMin  Float?
  peakHour        Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  service QueueService @relation(fields: [serviceId], references: [id])

  @@unique([serviceId, date])
  @@map("queue_daily_statistics")
}

// ════════════════════════════════════════════════════
// MODULE 9 — AI ASSISTANT
// ════════════════════════════════════════════════════

model AIConversation {
  id          String    @id @default(uuid())
  sessionId   String
  citizenId   String?
  language    String    @default("vi")
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  totalTokens Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  session         KioskSession       @relation(fields: [sessionId], references: [id])
  messages        AIMessage[]
  recommendations AIRecommendation[]

  @@index([sessionId])
  @@map("ai_conversations")
}

model AIMessage {
  id             String      @id @default(uuid())
  conversationId String
  role           MessageRole
  content        String
  inputType      String?
  intent         String?
  confidence     Float?
  tokensUsed     Int?
  responseTimeMs Int?
  createdAt      DateTime    @default(now())

  conversation AIConversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId])
  @@map("ai_messages")
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model AIIntent {
  id          String    @id @default(uuid())
  name        String    @unique
  category    String?
  description String?
  examples    String[]
  responses   Json?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@map("ai_intents")
}

model AIRecommendation {
  id             String   @id @default(uuid())
  conversationId String
  procedureId    String?
  title          String
  description    String?
  confidence     Float?
  wasAccepted    Boolean?
  createdAt      DateTime @default(now())

  conversation AIConversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId])
  @@map("ai_recommendations")
}

// ════════════════════════════════════════════════════
// MODULE 9 — FEEDBACK
// ════════════════════════════════════════════════════

model FeedbackCategory {
  id        String    @id @default(uuid())
  code      String    @unique
  name      String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  feedbacks Feedback[]

  @@map("feedback_categories")
}

model Feedback {
  id         String         @id @default(uuid())
  sessionId  String
  citizenId  String?
  categoryId String?
  targetType FeedbackTarget
  targetId   String?
  score      Int
  starRating Int?
  comment    String?
  tags       String[]
  language   String         @default("vi")
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  deletedAt  DateTime?

  session  KioskSession      @relation(fields: [sessionId], references: [id])
  category FeedbackCategory? @relation(fields: [categoryId], references: [id])
  replies  FeedbackReply[]

  @@index([sessionId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("feedbacks")
}

enum FeedbackTarget {
  SERVICE
  OFFICER
