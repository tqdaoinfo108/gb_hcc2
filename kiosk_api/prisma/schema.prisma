// ════════════════════════════════════════════════════
// MODULE 14 — SELENIUM WORKFLOW AUTOMATION ENGINE
// ════════════════════════════════════════════════════

/// CMS-managed workflow template tied to an administrative procedure.
/// Defines which portal URL, auth method, and step sequence to use.
model WorkflowTemplate {
  id              String               @id @default(uuid())
  procedureId     String?
  code            String               @unique
  name            String
  description     String?
  targetUrl       String               // The government portal URL to automate
  portalCode      String?              // e.g. "CONG_DICH_VU_CONG", "DVC_QUOC_GIA"
  authMethod      WorkflowAuthMethod   @default(NONE)
  isActive        Boolean              @default(true)
  isPublished     Boolean              @default(false)
  timeoutSeconds  Int                  @default(120)
  maxRetries      Int                  @default(2)
  screenshotMode  ScreenshotMode       @default(ON_ERROR)
  configJson      Json?                // Extra portal-specific configs
  version         Int                  @default(1)
  publishedAt     DateTime?
  createdBy       String?
  updatedBy       String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  deletedAt       DateTime?

  steps    WorkflowStep[]
  jobs     SeleniumJob[]

  @@index([procedureId])
  @@map("workflow_templates")
}

enum WorkflowAuthMethod {
  NONE
  VNEID_QR
  CCCD_CHIP
  USERNAME_PASSWORD
  OTP_SMS
  SSO_TOKEN
}

enum ScreenshotMode {
  NEVER
  ON_ERROR
  ON_EACH_STEP
  ALWAYS
}

/// Individual step inside a WorkflowTemplate. Steps are ordered and typed.
/// CMS drag-and-drop builder writes rows here.
model WorkflowStep {
  id            String           @id @default(uuid())
  templateId    String
  stepOrder     Int
  stepType      WorkflowStepType
  name          String
  description   String?
  isRequired    Boolean          @default(true)

  // Navigation
  url           String?
  waitFor       String?          // CSS selector / XPath to wait for before acting
  waitTimeoutMs Int              @default(10000)

  // Element targeting (multiple strategies, tried in order)
  selector      String?          // Primary CSS/XPath selector
  selectorAlt   String?          // Fallback selector
  selectorType  SelectorType     @default(CSS)

  // Actions
  action        StepAction       @default(NONE)
  inputValue    String?          // Static value or {{citizen.field}} template
  inputMapping  Json?            // Map citizen profile fields → form fields
  uploadField   String?          // Field name for file upload

  // Validation
  assertText    String?          // Text that must exist after action
  assertUrl     String?          // URL pattern after navigation
  assertVisible String?          // Selector that must be visible

  // Control flow
  onFailure     StepFailureAction @default(STOP)
  retryCount    Int              @default(1)
  delayAfterMs  Int              @default(500)

  conditionExpr String?          // JS expression evaluated in browser context
  metadata      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  template WorkflowTemplate @relation(fields: [templateId], references: [id])

  @@index([templateId, stepOrder])
  @@map("workflow_steps")
}

enum WorkflowStepType {
  // ── Low-level primitives ──
  NAVIGATE           // Go to URL
  CLICK              // Click element
  FILL               // Type into input
  SELECT             // Select dropdown option
  UPLOAD             // Upload file
  WAIT               // Wait for element/condition
  SCREENSHOT         // Capture screenshot
  ASSERT             // Validate page state
  EXTRACT            // Pull data from page
  SCROLL             // Scroll element into view
  IFRAME_ENTER       // Switch into iframe
  IFRAME_EXIT        // Return to main frame
  CAPTCHA_WAIT       // Pause for human CAPTCHA solving
  CUSTOM_SCRIPT      // Execute JS snippet
  // ── High-level semantic steps (CMS-friendly, dichvucong.gov.vn) ──
  OPEN_URL                 // Open the portal landing URL
  CLICK_MENU               // Click a portal menu item
  SEARCH_PROCEDURE         // Type procedure name into portal search
  SELECT_RESULT            // Pick the correct search result
  WAIT_VNEID_LOGIN         // Pause for citizen VNeID authentication
  INPUT_FIELD              // Fill a mapped form field
  SELECT_OPTION            // Choose a dropdown/radio option
  UPLOAD_DOCUMENT          // Trigger Upload Manager + attach file
  WAIT_SUBMIT              // Wait for/confirm submit
  DETECT_SUCCESS_TEXT      // Detect success message text
  EXTRACT_APPLICATION_CODE // Pull the application/tracking code
  COMPLETE                 // Terminal success step
}

enum SelectorType {
  CSS
  XPATH
  ID
  NAME
  TEXT
  LINK_TEXT
}

enum StepAction {
  NONE
  CLICK
  DOUBLE_CLICK
  RIGHT_CLICK
  FILL
  CLEAR
  SELECT_OPTION
  HOVER
  SCROLL_TO
  KEY_PRESS
  SUBMIT
}

enum StepFailureAction {
  STOP              // Abort job immediately
  RETRY             // Retry this step
  SKIP              // Skip and continue
  SCREENSHOT_STOP   // Screenshot then stop
}

/// A Selenium runner instance (one per physical server/VM).
/// Runners self-register via POST /selenium/runners/register
model SeleniumRunner {
  id               String            @id @default(uuid())
  runnerId         String            @unique   // e.g. "runner-01"
  name             String
  host             String
  port             Int               @default(4444)
  status           RunnerStatus      @default(OFFLINE)
  capacity         Int               @default(5)  // max concurrent sessions
  activeSessions   Int               @default(0)
  browserType      BrowserType       @default(CHROMIUM)
  version          String?
  lastHeartbeatAt  DateTime?
  registeredAt     DateTime          @default(now())
  metadata         Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?

  sessions SeleniumSession[]
  jobs     SeleniumJob[]

  @@map("selenium_runners")
}

enum RunnerStatus {
  ONLINE
  BUSY
  OFFLINE
  ERROR
  DRAINING
}

enum BrowserType {
  CHROMIUM
  FIREFOX
  WEBKIT
}

/// An isolated browser session created per kiosk session.
/// 1 kiosk session → 1 selenium session (browser context).
model SeleniumSession {
  id              String              @id @default(uuid())
  runnerId        String
  kioskSessionId  String
  browserContextId String?            // Playwright/Selenium context ID
  status          SeleniumSessionStatus @default(CREATED)
  createdAt       DateTime            @default(now())
  destroyedAt     DateTime?
  cleanedAt       DateTime?

  runner SeleniumRunner @relation(fields: [runnerId], references: [id])
  jobs   SeleniumJob[]

  @@index([runnerId])
  @@index([kioskSessionId])
  @@map("selenium_sessions")
}

enum SeleniumSessionStatus {
  CREATED
  ACTIVE
  COMPLETED
  DESTROYED
  ERROR
}

/// A single workflow execution job.
model SeleniumJob {
  id              String        @id @default(uuid())
  templateId      String
  seleniumSessionId String?
  runnerId        String?
  applicationId   String?
  citizenId       String?
  kioskSessionId  String?
  status          JobStatus     @default(PENDING)
  priority        Int           @default(5)
  inputData       Json?         // Citizen profile + form data + document refs
  outputData      Json?         // Extracted data, result URLs, confirmation numbers
  applicationCode String?       // Tracking/application code detected on success
  submittedDeviceSerial String? // Kiosk that submitted (denormalized for fast lookup)
  currentStepId   String?
  currentStepOrder Int          @default(0)
  progressPercent Int           @default(0)
  startedAt       DateTime?
  completedAt     DateTime?
  failedAt        DateTime?
  failReason      String?
  retryCount      Int           @default(0)
  scheduledAt     DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  template        WorkflowTemplate  @relation(fields: [templateId], references: [id])
  seleniumSession SeleniumSession?  @relation(fields: [seleniumSessionId], references: [id])
  runner          SeleniumRunner?   @relation(fields: [runnerId], references: [id])
  logs            SeleniumJobLog[]
  screenshots     SeleniumScreenshot[]

  @@index([status, scheduledAt])
  @@index([kioskSessionId])
  @@index([runnerId])
  @@index([submittedDeviceSerial])
  @@index([applicationCode])
  @@map("selenium_jobs")
}

enum JobStatus {
  PENDING
  QUEUED
  RUNNING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
  RETRYING
}

model SeleniumJobLog {
  id         String      @id @default(uuid())
  jobId      String
  stepOrder  Int?
  stepName   String?
  level      LogLevel    @default(INFO)
  message    String
  detail     Json?
  durationMs Int?
  createdAt  DateTime    @default(now())

  job SeleniumJob @relation(fields: [jobId], references: [id])

  @@index([jobId, createdAt])
  @@map("selenium_job_logs")
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
}

model SeleniumScreenshot {
  id          String   @id @default(uuid())
  jobId       String
  stepOrder   Int?
  stepName    String?
  storagePath String
  bucketName  String?
  sizeBytes   Int?
  capturedAt  DateTime @default(now())

  job SeleniumJob @relation(fields: [jobId], references: [id])

  @@index([jobId])
  @@map("selenium_screenshots")
}

// ════════════════════════════════════════════════════
// MODULE 15 — AI WORKER SYSTEM
// ════════════════════════════════════════════════════

/// AI worker process registration. Each worker is a separate process/container.
model AIWorker {
  id              String         @id @default(uuid())
  workerId        String         @unique  // e.g. "ai-worker-01"
  name            String
  host            String?
  port            Int?
  status          WorkerStatus   @default(OFFLINE)
  capacity        Int            @default(10)  // max concurrent AI jobs
  activeJobs      Int            @default(0)
  modelType       String?        // e.g. "GPT-4o", "Gemini-1.5", "Local-Llama"
  capabilities    String[]       // ["INTENT", "QA", "PROCEDURE_MATCH", "DOC_ANALYZE"]
  version         String?
  lastHeartbeatAt DateTime?
  registeredAt    DateTime       @default(now())
  totalJobsHandled Int           @default(0)
  avgResponseMs   Float?
  errorRate       Float          @default(0)
  metadata        Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  jobs AIJob[]

  @@map("ai_workers")
}

enum WorkerStatus {
  ONLINE
  BUSY
  OFFLINE
  ERROR
  DRAINING
}

/// An AI processing job assigned to a specific worker.
model AIJob {
  id             String      @id @default(uuid())
  workerId       String?
  conversationId String?
  sessionId      String?
  jobType        AIJobType
  status         JobStatus   @default(PENDING)
  priority       Int         @default(5)
  inputPayload   Json        // The request data
  outputPayload  Json?       // The response data
  modelUsed      String?
  tokensIn       Int?
  tokensOut      Int?
  responseTimeMs Int?
  failReason     String?
  retryCount     Int         @default(0)
  scheduledAt    DateTime    @default(now())
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  worker AIWorker? @relation(fields: [workerId], references: [id])

  @@index([status, scheduledAt])
  @@index([workerId])
  @@index([jobType])
  @@map("ai_jobs")
}

enum AIJobType {
  INTENT_DETECTION       // Classify citizen intent from text/voice
  PROCEDURE_MATCH        // Find relevant procedures
  QA_RESPONSE            // Answer citizen question
  DOCUMENT_ANALYZE       // Analyze uploaded document image
  DOCUMENT_BOUNDARY      // Detect document corners in image
  OCR_EXTRACT            // Extract text from document image
  IMAGE_ENHANCE          // Enhance document image quality
  TRANSLATION            // Translate content
  SENTIMENT_ANALYSIS     // Analyze feedback sentiment
  SUMMARY                // Summarize content
}

// ════════════════════════════════════════════════════
// MODULE 15b — AI RUNNER REGISTRY (configurable providers)
// CMS-managed external AI provider endpoints the Gateway calls
// directly (Ollama / Gemini / OpenAI-compatible / private).
// Distinct from AIWorker (self-registering pull workers).
// ════════════════════════════════════════════════════

model AiRunner {
  id               String         @id @default(uuid())
  name             String
  provider         AiProvider
  endpoint         String                       // provider base URL
  modelName        String
  authKey          String?                      // encrypted at rest
  priority         Int            @default(5)    // lower = preferred
  timeoutMs        Int            @default(30000)
  maxConcurrent    Int            @default(4)
  activeJobs       Int            @default(0)
  capabilities     String[]                      // INTENT_DETECTION, QA_RESPONSE, PROCEDURE_MATCH...
  status           AiRunnerStatus @default(ENABLED)
  health           AiRunnerHealth @default(UNKNOWN)
  latencyMs        Float?
  failureRate      Float          @default(0)
  lastCheckAt      DateTime?
  lastOkAt         DateTime?
  consecutiveFails Int            @default(0)
  config           Json?
  version          Int            @default(1)
  tenantId         String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?

  healthLogs AiRunnerHealthLog[]

  @@index([status, health, priority])
  @@map("ai_runners")
}

enum AiProvider {
  OLLAMA
  GEMINI
  OPENAI_COMPAT
  PRIVATE
}

enum AiRunnerStatus {
  ENABLED
  DISABLED
}

enum AiRunnerHealth {
  HEALTHY
  DEGRADED
  UNHEALTHY
  UNKNOWN
}

model AiRunnerHealthLog {
  id         String   @id @default(uuid())
  runnerId   String
  ok         Boolean
  latencyMs  Float?
  httpStatus Int?
  error      String?
  checkedAt  DateTime @default(now())

  runner AiRunner @relation(fields: [runnerId], references: [id], onDelete: Cascade)

  @@index([runnerId, checkedAt])
  @@map("ai_runner_health_logs")
}

// ════════════════════════════════════════════════════
// MODULE 16 — SAO Y (ELECTRONIC DOCUMENT COPY)
// ════════════════════════════════════════════════════

/// CMS-managed document category catalog with pricing rules.
model CopyDocCategory {
  id             String    @id @default(uuid())
  locationId     String?   // null = dùng chung cho mọi địa điểm
  code           String
  name           String
  nameEn         String?
  description    String?
  icon           String?
  colorHex       String?
  sortOrder      Int       @default(0)
  isActive       Boolean   @default(true)
  // Pricing
  pricePerCopy   Decimal   @db.Decimal(15, 2) @default(0)
  processingFeeRate Decimal @db.Decimal(5, 4) @default(0.1) // 10% default
  maxCopiesPerRequest Int  @default(10)
  // Legal
  legalBasis     String?
  validityDays   Int       @default(0)  // 0 = no expiry
  requiresStamp  Boolean   @default(true)
  // OCR Auto-detection configuration
  ocrKeywords      String[]   // OCR text keywords that map to this category
  ocrDocTypes      String[]   // Document type codes (e.g. "CCCD", "BIRTH_CERT")
  ocrMinScore      Int        @default(1)   // Min keyword matches to auto-select
  pdfTemplateName  String?    // PDF layout variant name
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  location KioskLocation?  @relation(fields: [locationId], references: [id])
  requests CopyDocRequest[]
  feeRules CopyDocFeeRule[]

  @@unique([locationId, code])
  @@index([locationId])
  @@map("copy_doc_categories")
}

/// Tiered/override fee rules for a category. Evaluated top-to-bottom.
model CopyDocFeeRule {
  id           String          @id @default(uuid())
  categoryId   String
  ruleName     String
  minQuantity  Int             @default(1)
  maxQuantity  Int?
  pricePerCopy Decimal         @db.Decimal(15, 2)
  feeType      CopyDocFeeType  @default(FIXED)
  isActive     Boolean         @default(true)
  effectiveFrom DateTime       @default(now())
  effectiveTo  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  category CopyDocCategory @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@map("copy_doc_fee_rules")
}

enum CopyDocFeeType {
  FIXED          // flat price per copy
  PROGRESSIVE    // price drops per tier
  EXEMPT         // free (e.g. social policy)
}

/// The main copy request created when citizen starts the sao-y service.
model CopyDocRequest {
  id             String              @id @default(uuid())
  categoryId     String?
  sessionId      String
  citizenId      String?
  kioskDeviceId  String?
  requestCode    String              @unique  // e.g. SY-2026-12345
  status         CopyRequestStatus   @default(INITIATED)
  quantity       Int                 @default(1)
  baseFee        Decimal             @db.Decimal(15, 2) @default(0)
  processingFee  Decimal             @db.Decimal(15, 2) @default(0)
  totalFee       Decimal             @db.Decimal(15, 2) @default(0)
  feeConfirmedAt DateTime?
  paymentRef     String?
  receiptCode    String?             @unique
  digitalDocId   String?             // Link to saved DigitalDocument
  rawImagePath           String?
  processedImagePath     String?
  pdfPath                String?
  detectedCategoryId     String?
  detectedTypeLabel      String?
  detectedTypeConfidence Float?
  ocrText                String?   @db.Text   // Full OCR text extracted client-side
  ocrOrientation         Int?                 // Rotation applied to upright the doc (0/90/180/270)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  completedAt    DateTime?
  deletedAt      DateTime?

  category       CopyDocCategory?     @relation(fields: [categoryId], references: [id])
  scanSessions   MobileScanSession[]
  aiJobs         DocAIProcessingJob[]
  printJobs      PrintJob[]
  feeTransaction FeeTransaction?
  pages          CopyDocPage[]

  @@index([sessionId])
  @@index([status])
  @@map("copy_doc_requests")
}

/// One scanned page of a copy request. Multi-page documents create several
/// rows; classification is driven by pageIndex = 0 (the first page).
model CopyDocPage {
  id                 String   @id @default(uuid())
  requestId          String
  pageIndex          Int      // 0-based display order
  rawImagePath       String   // upright original (client orientation-fixed)
  processedImagePath String?  // perspective-cropped result (the printable copy)
  ocrText            String?  @db.Text
  ocrOrientation     Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  request CopyDocRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@unique([requestId, pageIndex])
  @@index([requestId])
  @@map("copy_doc_pages")
}

enum CopyRequestStatus {
  INITIATED          // Request created, QR shown
  SCAN_PENDING       // Waiting for mobile scan
  SCAN_IN_PROGRESS   // Mobile connected, uploading
  SCAN_COMPLETE      // Images received
  AI_PROCESSING      // AI analysing images
  PREVIEW_READY      // Corners detected, showing preview
  ADJUSTED           // Citizen confirmed crop
  FEE_PENDING        // Showing fee, waiting confirmation
  FEE_CONFIRMED      // Citizen confirmed payment
  GENERATING_PDF     // Creating electronic copy
  PRINT_QUEUED       // Sent to printer queue
  PRINTING           // Printing in progress
  COMPLETED          // Printed and saved to wallet
  FAILED             // Terminal failure
  CANCELLED          // Citizen cancelled
}

/// Mobile QR scan session — tracks the temporary link used to connect
/// the citizen's phone to the kiosk copy request.
model MobileScanSession {
  id            String              @id @default(uuid())
  requestId     String
  sessionToken  String              @unique @default(uuid())
  qrPayload     String              // URL encoded in QR
  status        ScanSessionStatus   @default(PENDING)
  mobileUA      String?             // Mobile browser user-agent
  mobileIp      String?
  connectedAt   DateTime?
  uploadedAt    DateTime?
  expiresAt     DateTime
  scanImages    Json?               // Array of {url, side, uploadedAt}
  rawImagePaths String[]            // Storage paths before processing
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  request CopyDocRequest @relation(fields: [requestId], references: [id])

  @@index([requestId])
  @@map("mobile_scan_sessions")
}

enum ScanSessionStatus {
  PENDING        // QR generated, not yet scanned
  CONNECTED      // Mobile opened the link
  UPLOADING      // Images being uploaded
  COMPLETE       // All images received
  EXPIRED        // Token expired
  ERROR
}

/// AI Document processing job for image analysis, boundary detection, enhancement.
/// Each request may spawn multiple jobs (1 per image or per AI task type).
model DocAIProcessingJob {
  id             String           @id @default(uuid())
  requestId      String
  aiJobId        String?          // Links to AIJob for routing/tracking
  jobType        AIJobType        @default(DOCUMENT_ANALYZE)
  inputImagePath String
  status         JobStatus        @default(PENDING)
  // Raw AI output
  detectedType   String?          // e.g. "CCCD", "BIRTH_CERTIFICATE"
  confidence     Float?
  boundaryPoints Json?            // [{x,y}] 4 corners in pixel coords
  enhancedPath   String?          // Storage path of enhanced image
  ocrText        String?          // Extracted text (internal only)
  metadata       Json?
  errorMessage   String?
  processedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  request CopyDocRequest @relation(fields: [requestId], references: [id])

  @@index([requestId])
  @@map("doc_ai_processing_jobs")
}

// ════════════════════════════════════════════════════
// MODULE 17 — PRINT & FEE TRANSACTIONS
// ════════════════════════════════════════════════════

model PrintJob {
  id              String        @id @default(uuid())
  copyRequestId   String?
  kioskDeviceId   String?
  sessionId       String?
  jobType         PrintJobType  @default(DOCUMENT_COPY)
  status          PrintStatus   @default(QUEUED)
  filePath        String?       // PDF path to print
  copies          Int           @default(1)
  printerName     String?
  printerStatus   String?
  sentAt          DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  failReason      String?
  retryCount      Int           @default(0)
  outputPageCount Int?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  copyRequest CopyDocRequest? @relation(fields: [copyRequestId], references: [id])

  @@index([status])
  @@index([kioskDeviceId])
  @@map("print_jobs")
}

enum PrintJobType {
  DOCUMENT_COPY
  SUBMISSION_RECEIPT
  QUEUE_TICKET
  REPORT
}

enum PrintStatus {
  QUEUED
  READY_TO_PRINT
  PRINTING
  COMPLETED
  FAILED
  CANCELLED
}

model FeeTransaction {
  id              String              @id @default(uuid())
  copyRequestId   String?             @unique
  transactionRef  String              @unique @default(uuid())
  citizenId       String?
  amount          Decimal             @db.Decimal(15, 2)
  currency        String              @default("VND")
  paymentMethod   PaymentMethod       @default(CASH)
  status          PaymentStatus       @default(PENDING)
  confirmedAt     DateTime?
  confirmedBy     String?             // Admin/operator who confirmed
  receiptNumber   String?             @unique
  metadata        Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  copyRequest CopyDocRequest? @relation(fields: [copyRequestId], references: [id])

  @@index([status])
  @@index([createdAt])
  @@map("fee_transactions")
}

enum PaymentMethod {
  CASH
  VNPAY
  MOMO
  BANKING
  WAIVED    // Exempt / free
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
  REFUNDED
  WAIVED
}
